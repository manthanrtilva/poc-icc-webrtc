+ */
+
+#include "examples/peerconnection/client/linux/cli_wnd.h"
+
+#include <stddef.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include <iostream>
+#include <map>
+
+#include "api/media_stream_interface.h"
+#include "api/scoped_refptr.h"
+#include "api/video/i420_buffer.h"
+#include "api/video/video_frame.h"
+#include "api/video/video_frame_buffer.h"
+#include "api/video/video_rotation.h"
+#include "api/video/video_source_interface.h"
+#include "examples/peerconnection/client/main_wnd.h"
+#include "examples/peerconnection/client/peer_connection_client.h"
+#include "rtc_base/checks.h"
+#include "rtc_base/logging.h"
+#include "third_party/libyuv/include/libyuv/convert_from.h"
+
+CliMainWnd::CliMainWnd(const char* server,
+                       int port,
+                       bool autoconnect,
+                       bool autocall)
+    : callback_(NULL),
+      server_(server),
+      port_(port),
+      autoconnect_(autoconnect),
+      autocall_(autocall) {}
+
+CliMainWnd::~CliMainWnd() {
+  RTC_DCHECK(!IsWindow());
+}
+
+void CliMainWnd::RegisterObserver(MainWndCallback* callback) {
+  callback_ = callback;
+}
+
+bool CliMainWnd::IsWindow() {
+  return is_running_;
+}
+
+void CliMainWnd::MessageBox(const char* caption,
+                            const char* text,
+                            bool is_error) {}
+
+MainWindow::UI CliMainWnd::current_ui() {
+  return STREAMING;
+}
+
+void CliMainWnd::StartLocalRenderer(webrtc::VideoTrackInterface* local_video) {
+  local_renderer_.reset(new VideoRenderer(this, local_video));
+}
+
+void CliMainWnd::StopLocalRenderer() {
+  local_renderer_.reset();
+}
+
+void CliMainWnd::StartRemoteRenderer(
+    webrtc::VideoTrackInterface* remote_video) {
+  remote_renderer_.reset(new VideoRenderer(this, remote_video));
+}
+
+void CliMainWnd::StopRemoteRenderer() {
+  remote_renderer_.reset();
+}
+
+void CliMainWnd::QueueUIThreadCallback(int msg_id, void* data) {}
+
+bool CliMainWnd::Create() {
+  client_thread_ = std::thread([this]() {
+    while (is_running_) {
+      std::cout << ">>>";
+      std::string line;
+      std::getline(std::cin, line);
+      if (line == "exit") {
+        is_running_ = false;
+      }
+    }
+  });
+  command_queue_.push_back([this]() { SwitchToConnectUI(); });
+  return true;
+}
+
+bool CliMainWnd::Destroy() {
+  if (!IsWindow())
+    return false;
+  OnDestroyed();
+  if (client_thread_.joinable()) {
+    client_thread_.join();
+  }
+  return true;
+}
+void CliMainWnd::RunEventLoop() {
+  while (command_queue_.empty() == false) {
+    auto command = command_queue_.front();
+    command_queue_.pop_front();
+    command();
+  }
+}
+void CliMainWnd::SwitchToConnectUI() {
+  RTC_LOG(LS_INFO) << __FUNCTION__;
+
+  RTC_DCHECK(IsWindow());
+  if (autoconnect_) {
+    callback_->StartLogin(server_, port_);
+  }
+}
+
+void CliMainWnd::SwitchToPeerList(const Peers& peers) {
+  RTC_LOG(LS_INFO) << __FUNCTION__;
+}
+
+void CliMainWnd::SwitchToStreamingUI() {
+  RTC_LOG(LS_INFO) << __FUNCTION__;
+}
+
+void CliMainWnd::OnDestroyed() {
+  callback_->Close();
+}
+
+void CliMainWnd::OnClicked() {
+  // Make the connect button insensitive, so that it cannot be clicked more than
+  // once.  Now that the connection includes auto-retry, it should not be
+  // necessary to click it more than once.
+  callback_->StartLogin(server_, port_);
+}
+
+void CliMainWnd::OnKeyPress() {}
+
+void CliMainWnd::OnRowActivated() {}
+
+void CliMainWnd::OnRedraw() {}
+
+void CliMainWnd::Draw() {}
+
+CliMainWnd::VideoRenderer::VideoRenderer(
+    CliMainWnd* main_wnd,
+    webrtc::VideoTrackInterface* track_to_render)
+    : width_(0),
+      height_(0),
+      main_wnd_(main_wnd),
+      rendered_track_(track_to_render) {
+  rendered_track_->AddOrUpdateSink(this, webrtc::VideoSinkWants());
+}
+
+CliMainWnd::VideoRenderer::~VideoRenderer() {
+  rendered_track_->RemoveSink(this);
+}
+
+void CliMainWnd::VideoRenderer::SetSize(int width, int height) {}
+
+void CliMainWnd::VideoRenderer::OnFrame(const webrtc::VideoFrame& video_frame) {
+}

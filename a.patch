+bool GtkMainWnd::Create() {
+  RTC_DCHECK(window_ == NULL);
+RTC_LOG(LS_INFO) << __FUNCTION__;
+std::thread th{[this](){
+  std::string line;
+  std::cout<<">>";
+  while (std::getline(std::cin, line)) {
+    if (line == "exit") {
+      OnDestroyed(nullptr, nullptr);
+      break;
+    } else if (line.rfind("connect ", 0) == 0) {
+      std::istringstream iss(line);
+      std::string cmd, ip, port_str;
+      
+      if (iss >> cmd >> ip >> port_str) {
+        // Successfully parsed all 4 parts
+        int port = std::stoi(port_str);
+        
+        RTC_LOG(LS_INFO) << "Connect command: ip=" << ip 
+                         << " port=" << port;
+        
+        // Use the parsed values
+        server_ = ip;
+        thread_callbacks_.push_back([this, port](){
+          callback_->StartLogin(server_, port);
+        });
+        
+        // You can also use peer_id as needed
+      } else {
+        std::cout << "Usage: connect <ip> <port> <id>" << std::endl;
+      }
+    }
+    std::cout<<">>";
+  }
+}};
+th.detach();
+  return true;
+}
